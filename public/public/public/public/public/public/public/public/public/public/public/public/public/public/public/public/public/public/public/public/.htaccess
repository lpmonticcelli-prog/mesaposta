<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # ==============================================================================
    # 1. ESCUDO ANTI-BOTNETS (Impede sobrecarga de CPU na HostGator)
    # ==============================================================================
    RewriteCond %{HTTP_USER_AGENT} ^-?$ [OR]
    RewriteCond %{HTTP_USER_AGENT} ^$ [OR]
    RewriteCond %{HTTP_USER_AGENT} (Acunetix|AhrefsBot|Baiduspider|BLEXBot|DirBuster|DotBot|MJ12bot|MegaIndex|Nmap|PetalBot|SemrushBot|YandexBot|ZmEu|sqlmap|scanner|nikto|wpscan|wordpress) [NC]
    RewriteRule ^ - [F,L]

    # ==============================================================================
    # 2. PROTEÇÃO DO COFRE DE DADOS
    # ==============================================================================
    RewriteRule ^(\.env|\.git|\.htaccess|composer\.json|package\.json|artisan|storage/logs) - [F,L,NC]

    # ==============================================================================
    # 3. REGRAS CORE DO LARAVEL (OBRIGATÓRIO)
    # ==============================================================================
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>

<IfModule mod_headers.c>
    Header always append X-Frame-Options SAMEORIGIN
    Header set X-XSS-Protection "1; mode=block"
    Header set X-Content-Type-Options nosniff
    Header unset X-Powered-By
</IfModule>

ServerSignature Off